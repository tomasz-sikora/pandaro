# Pandaro configuration — copy to `.env` and adjust. All vars use the PANDARO_ prefix
# (except HF_TOKEN). Defaults are tuned for a single RTX 3090 (24GB) + host Ollama.

# --- Server -----------------------------------------------------------------
PANDARO_HOST=0.0.0.0
PANDARO_PORT=8080
PANDARO_FRONTEND_DIST=frontend/dist
PANDARO_MAX_UPLOAD_MB=2048

# --- Ollama (LLM + embeddings run on the host, not in the container) --------
# In Docker, reach the host via host.docker.internal (see compose.yaml).
PANDARO_OLLAMA_HOST=http://localhost:11434
# User requested "Gemma 4"; if the tag is absent on Ollama, fall back cleanly.
PANDARO_LLM_MODEL=gemma4
PANDARO_LLM_MODEL_FALLBACK=gemma3:27b
PANDARO_EMBEDDING_MODEL=bge-m3
# "0" unloads the model immediately after each call to free VRAM for ASR/etc.
PANDARO_OLLAMA_KEEP_ALIVE=0

# --- HuggingFace ------------------------------------------------------------
# Needed for gated models (pyannote diarization). Used as a build secret AND at
# runtime for lazy downloads. Never commit a real token.
HF_TOKEN=
PANDARO_HF_HOME=/cache/huggingface

# --- ASR (precision-first) --------------------------------------------------
PANDARO_ASR_BACKEND=faster-whisper   # faster-whisper | whisperx | stub
PANDARO_ASR_MODEL=large-v3
PANDARO_ASR_COMPUTE_TYPE=float16     # float16 | int8_float16 | int8 (low-VRAM)
PANDARO_ASR_BEAM_SIZE=5
PANDARO_CONFIDENCE_THRESHOLD=0.55

# --- Diarization ------------------------------------------------------------
PANDARO_DIARIZATION_BACKEND=pyannote # pyannote | nemo | stub
PANDARO_DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# --- Hardware / VRAM (24GB shared with Ollama) ------------------------------
PANDARO_DEVICE=auto                  # auto | cuda | cpu
PANDARO_MAX_RESIDENT_MODELS=1        # one heavy model on the GPU at a time
PANDARO_LOW_VRAM=false               # true → int8 + aggressive CPU offload

# --- Pipeline ---------------------------------------------------------------
PANDARO_DEFAULT_LANGUAGE=pl
PANDARO_TRANSLATE_TARGET=pl
PANDARO_SUMMARY_CHUNK_CHARS=8000
